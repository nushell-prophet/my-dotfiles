#!/usr/bin/env -S nu --stdin
# Column-aware block writer for the Helix<->nushell bridge.
#
# Shebang uses `--stdin` because: a nu script does NOT read process stdin into
# `$in` by default (only the `--stdin` flag does). It only matters for
# standalone shell calls — the `+ b` binding reaches this file via nushell's
# `run` keyword (nu-hx block-below), where pipeline input feeds main's $in
# directly, no process stdin involved.
#
# Helix's built-in `!` (shell_insert_output) ignores the column: it drops the
# command's output flush-left and shoves the rest of the line down. This instead
# writes the output as a RECTANGLE. Each row overwrites only the columns the
# block covers; the text to the left and right of the block on every line is
# preserved. Rows past the end of the file are added as blank lines first.
#
# The block text arrives on stdin. Coordinates come from Helix's variable
# expansion, so `line`/`--col` are 1-based and counted in grapheme clusters (the
# same count the statusline shows). Why graphemes: a column over "👨‍👩‍👧" or a
# combining mark must land where Helix thinks it is, not where a byte/scalar
# count would put it.

def spaces [n: int] { "" | fill --character ' ' --width ([$n 0] | math max) }

def main [
    file: string   # buffer path (Helix %{buffer_name})
    line: int      # 1-based anchor line
    # --below declared BEFORE --col because: `run` (nu 0.114) binds flags by
    # declaration position, not name — nu-hx block-below passes --below, which
    # must land on the first flag slot. The order stays correct once run is fixed.
    --below        # place the block on line+1, aligned to `line`'s leading indent (ignores --col)
                   # Why: `+ b` keeps the selected command and grows the table below it.
    --col: int     # 1-based left column of the block (cursor mode)
] {
    let raw = $in | default "" | into string
    if ($raw | is-empty) { return }   # producer printed nothing -> leave buffer untouched

    let block = $raw | str replace -r '\n$' '' | split row "\n"   # drop one trailing newline
    let h = $block | length
    let w = $block | each { str length --grapheme-clusters } | math max   # rectangle width

    let orig = open --raw $file | into string
    let had_nl = ($orig | str ends-with "\n")
    mut flines = $orig | split row "\n"
    # a trailing newline yields a phantom final "" element; drop it and restore the newline on save
    if $had_nl and (($flines | last) == "") { $flines = ($flines | drop) }

    # resolve the 0-based top-left anchor
    let row0 = if $below { $line } else { $line - 1 }   # --below: the line *after* `line`
    let col0 = if $below {
        # align under the command: start at its first non-blank column
        let cmdline = $flines | get --optional ($line - 1) | default ""
        $cmdline | split chars --grapheme-clusters | take while {|c| $c =~ '^\s$' } | length
    } else {
        ($col | default 1) - 1
    }

    # grow the file with blank lines so the block has rows to land on
    let need = $row0 + $h
    let cur = $flines | length
    if $cur < $need { $flines = ($flines | append (0..<($need - $cur) | each { "" })) }

    for i in 0..<$h {
        let target = $row0 + $i
        let existing = $flines | get $target
        let eg = $existing | split chars --grapheme-clusters
        let elen = $eg | length
        # keep everything left of the block; pad with spaces if the line is shorter than the start column
        let left = if $elen >= $col0 { $eg | first $col0 | str join } else { $existing + (spaces ($col0 - $elen)) }
        # pad the block row to the rectangle width so the preserved right side stays column-aligned
        let brow = $block | get $i
        let bpad = $brow + (spaces ($w - ($brow | str length --grapheme-clusters)))
        # keep whatever sits to the right of the block (the part that still fits)
        let cut = $col0 + $w
        let right = if $elen > $cut { $eg | skip $cut | str join } else { "" }
        $flines = ($flines | update $target ($left + $bpad + $right))
    }

    let out = $flines | str join "\n"
    (if $had_nl { $out + "\n" } else { $out }) | save -f $file
}
